PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=your_mongodb_uri

# Authentication
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
SETUP_SECRET=your_setup_secret

# AWS Configuration (S3 & SES)
ADMIN_EMAIL=your_verified_sender_email
AWS_REGION=ap-south-1
EMAIL_SERVICE=ses-smtp
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your_bucket_name
S3_PUBLIC_BASE_URL=https://your_bucket_name.s3.amazonaws.com

# SES SMTP Details
SES_SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USERNAME=your_smtp_username
SES_SMTP_PASSWORD=your_smtp_password

# Payment Gateway
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Sheets
GOOGLE_SHEET_ID=your_sheet_id
# If not using env for credentials, ensure google-credentials.json is in root
